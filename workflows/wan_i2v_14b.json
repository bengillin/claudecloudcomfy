{
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "main_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "wan2.2_vae.safetensors",
      "precision": "bf16"
    }
  },
  "3": {
    "class_type": "WanVideoTextEncodeCached",
    "inputs": {
      "model_name": "umt5_xxl_fp16.safetensors",
      "precision": "bf16",
      "positive_prompt": "The scene comes to life with natural, fluid motion. Cinematic quality, smooth camera movement.",
      "negative_prompt": "blurry, low quality, distorted, watermark, text, ugly, static, frozen",
      "quantization": "disabled",
      "use_disk_cache": true,
      "device": "gpu"
    }
  },
  "4": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "INPUT_IMAGE_HASH"
    }
  },
  "6": {
    "class_type": "WanVideoImageClipEncode",
    "inputs": {
      "clip_vision": ["4", 0],
      "image": ["5", 0],
      "vae": ["2", 0],
      "generation_width": 832,
      "generation_height": 480,
      "num_frames": 81,
      "force_offload": true,
      "noise_aug_strength": 0.0,
      "latent_strength": 1.0,
      "clip_embed_strength": 1.0,
      "adjust_resolution": true
    }
  },
  "7": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "image_embeds": ["6", 0],
      "text_embeds": ["3", 0],
      "steps": 30,
      "cfg": 5.0,
      "shift": 5.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0
    }
  },
  "8": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["2", 0],
      "samples": ["7", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "9": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["8", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "wan_i2v",
      "format": "video/h265-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
